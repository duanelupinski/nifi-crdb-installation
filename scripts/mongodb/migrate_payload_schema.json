{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/migrate.json",
  "type": "object",
  "required": ["migrationId", "sourceMongo", "targetCrdb", "collections"],
  "properties": {
    "migrationId": { "type": "string", "minLength": 1 },
    "dryRun": { "type": "boolean", "default": false },
    "priority": { "type": "string", "enum": ["low", "normal", "high"], "default": "normal" },

    "orchestrator": {
      "type": "object",
      "properties": {
        "runOwner": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notifyWebhook": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },

    "sourceMongo": {
      "type": "object",
      "required": ["connectionUri", "database"],
      "properties": {
        "connectionUri": { "type": "string", "minLength": 1 },
        "database": { "type": "string", "minLength": 1 },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "passwordSecretRef": { "type": "string" }
          },
          "additionalProperties": false
        },
        "tls": {
          "type": "object",
          "properties": {
            "verifyPeer": { "type": "boolean", "default": true },
            "caCertSecretRef": { "type": "string" }
          },
          "additionalProperties": false
        },
        "readConcern": { "type": "string" },
        "writeConcern": { "type": "string" },
        "maxDocsPerBatch": { "type": "integer", "minimum": 1 },
        "cursorBatchSize": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },

    "targetCrdb": {
      "type": "object",
      "required": ["sqlEndpoint"],
      "properties": {
        "sqlEndpoint": { "type": "string", "minLength": 1 },
        "auth": {
          "type": "object",
          "properties": {
            "passwordSecretRef": { "type": "string" }
          },
          "additionalProperties": false
        },
        "schema": { "type": "string", "default": "public" },
        "tempSchema": { "type": "string" },
        "pooling": {
          "type": "object",
          "properties": {
            "maxConnections": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "ddl": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["generate_only", "apply", "generate_if_missing"],
          "default": "generate_if_missing"
        },
        "naming": {
          "type": "object",
          "properties": {
            "tablePrefix": { "type": "string", "default": "" },
            "tableSuffix": { "type": "string", "default": "" },
            "snakeCase": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        },
        "typeMappingOverrides": { "type": "object", "additionalProperties": { "type": "string" } },
        "primaryKey": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["infer", "explicit"], "default": "infer" },
            "explicitKeys": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
          },
          "additionalProperties": false
        },
        "indexes": {
          "type": "object",
          "properties": {
            "carryUnique": { "type": "boolean", "default": true },
            "carrySecondary": { "type": "boolean", "default": false }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "snapshot": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "parallelCollections": { "type": "integer", "minimum": 1, "default": 3 },
        "documentLimit": { "type": ["integer", "null"], "minimum": 1 },
        "avro": {
          "type": "object",
          "properties": {
            "output": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["filesystem", "s3", "gcs"] },
                "basePath": { "type": "string" },
                "compression": { "type": "string", "enum": ["none", "deflate", "snappy", "zstd"], "default": "snappy" }
              },
              "required": ["type", "basePath"],
              "additionalProperties": false
            },
            "recordNaming": { "type": "string", "enum": ["table_per_record", "single_union"], "default": "table_per_record" },
            "logicalTypeHints": { "type": "boolean", "default": true },
            "schemaRegistry": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "load": {
          "type": "object",
          "properties": {
            "method": { "type": "string", "enum": ["insert", "upsert", "copy_via_avro"], "default": "copy_via_avro" },
            "batchRows": { "type": "integer", "minimum": 1, "default": 5000 },
            "maxInFlightBatches": { "type": "integer", "minimum": 1, "default": 8 },
            "staging": {
              "type": "object",
              "properties": {
                "useTempTables": { "type": "boolean", "default": true },
                "swapAtomic": { "type": "boolean", "default": true }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "cdc": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "startPoint": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["now", "clusterTime", "resumeToken"], "default": "clusterTime" },
            "clusterTime": { "type": ["string", "null"], "format": "date-time" },
            "resumeToken": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "publish": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["direct", "kafka"], "default": "direct" },
            "kafka": {
              "type": "object",
              "properties": {
                "bootstrapServers": { "type": "string" },
                "sasl": { "type": ["object", "null"] },
                "topicPrefix": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "retry": {
          "type": "object",
          "properties": {
            "maxAttempts": { "type": "integer", "minimum": 0, "default": 100 },
            "backoffMs": { "type": "integer", "minimum": 0, "default": 500 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "schemaConversion": {
      "type": "object",
      "description": "Rules to convert Mongo schema to CRDB DDL.",
      "properties": {
        "defaultStrategy": { "type": "string", "enum": ["tableize", "jsonb"], "default": "tableize" },
        "arrayStrategy": { "type": "string", "enum": ["child_table", "jsonb", "junction_table"], "default": "child_table" },
        "mapStrategy": { "type": "string", "enum": ["kv_table", "jsonb"], "default": "jsonb" },
        "maxVarchar": { "type": "integer", "minimum": 1, "default": 1024 },
        "decimalDefault": { "type": "string", "pattern": "^DECIMAL\\(\\d+,\\d+\\)$", "default": "DECIMAL(38,9)" },
        "timeTzDefault": { "type": "string", "enum": ["TIMESTAMPTZ", "TIMESTAMP"], "default": "TIMESTAMPTZ" },
        "idStrategy": { "type": "string", "enum": ["use_objectid", "uuid", "natural"], "default": "use_objectid" },
        "fkOnDelete": { "type": "string", "enum": ["NO ACTION", "CASCADE", "SET NULL", "RESTRICT"], "default": "CASCADE" },
        "flattenDepth": { "type": "integer", "minimum": 0, "default": 1 },

        "pathOverrides": {
          "type": "array",
          "description": "Per-path rules using dotted Mongo paths. Arrays use [] notation.",
          "items": {
            "type": "object",
            "required": ["path", "strategy"],
            "properties": {
              "path": { "type": "string" },
              "strategy": { "type": "string", "enum": ["tableize", "jsonb", "flatten"] },
              "targetTable": { "type": "string" },
              "pk": { "type": "array", "items": { "type": "string" } },
              "unique": { "type": "array", "items": { "type": "string" } },
              "indexes": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
              "typeOverride": { "type": "string" },
              "nullable": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "collections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "target": {
            "type": "object",
            "properties": {
              "baseTable": { "type": "string" },
              "tablePerNested": { "type": "boolean", "default": true },
              "flattenArrays": { "type": "boolean", "default": false }
            },
            "additionalProperties": false
          },
          "filters": {
            "type": ["object", "null"]
          },
          "fieldTransforms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "op"],
              "properties": {
                "path": { "type": "string" },
                "op": { "type": "string" },
                "args": {}
              },
              "additionalProperties": false
            }
          },
          "keys": {
            "type": "object",
            "properties": {
              "primary": { "type": "array", "items": { "type": "string" } },
              "natural": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "conflicts": {
            "type": "object",
            "properties": {
              "onLoad": { "type": "string", "enum": ["fail", "upsert", "ignore"], "default": "upsert" },
              "onCdc": { "type": "string", "enum": ["fail", "upsert", "ignore"], "default": "upsert" }
            },
            "additionalProperties": false
          },
          "schemaConversion": { "$ref": "#/properties/schemaConversion" }
        },
        "additionalProperties": false
      }
    },

    "safety": {
      "type": "object",
      "properties": {
        "prechecks": { "type": "array", "items": { "type": "string" } },
        "stopIfRowCountMismatchPct": { "type": "number", "minimum": 0, "maximum": 100, "default": 5.0 },
        "stopOnDdlError": { "type": "boolean", "default": true },
        "allowDropOnRegenerate": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

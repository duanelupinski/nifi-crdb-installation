{
  "migrationId": "customer-db-2025-09-12",
  "dryRun": false,
  "priority": "normal",
  "orchestrator": {
    "runOwner": "some.body@cockroachlabs.com",
    "tags": ["mongodb->crdb", "pilot"],
    "notifyWebhook": "https://example.com/hooks/migration-status"
  },

  "sourceMongo": {
    "connectionUri": "mongodb+srv://cluster0.xxxx.mongodb.net",
    "auth": {
      "username": "svc_migrate",
      "passwordSecretRef": "vault://kv/mongo/svc_migrate"
    },
    "database": "appcatalog",
    "tls": { "verifyPeer": true, "caCertSecretRef": "vault://kv/mongo/ca" },
    "readConcern": "majority",
    "writeConcern": "majority",
    "maxDocsPerBatch": 10000,
    "cursorBatchSize": 1000
  },

  "targetCrdb": {
    "sqlEndpoint": "postgresql://roach@crdb-serverless:26257/appcatalog?sslmode=require",
    "auth": {
      "passwordSecretRef": "vault://kv/crdb/roach"
    },
    "schema": "public",
    "tempSchema": "stage_migrate",
    "pooling": { "maxConnections": 16 }
  },

  "ddl": {
    "mode": "generate_if_missing",
    "naming": {
      "tablePrefix": "",
      "tableSuffix": "",
      "snakeCase": true
    },
    "typeMappingOverrides": {
      "ObjectId": "STRING",
      "Decimal128": "DECIMAL(38,9)"
    },
    "primaryKey": {
      "strategy": "infer",
      "explicitKeys": {
        "products": ["id"],
        "orders": ["orderId"]
      }
    },
    "indexes": {
      "carryUnique": true,
      "carrySecondary": false
    }
  },

  "snapshot": {
    "enabled": true,
    "parallelCollections": 3,
    "documentLimit": null,
    "avro": {
      "output": {
        "type": "filesystem",
        "basePath": "/data/migrations/customer-db-2025-09-12",
        "compression": "snappy"
      },
      "recordNaming": "table_per_record",
      "logicalTypeHints": true,
      "schemaRegistry": "http://schema-registry:8081"
    },
    "load": {
      "method": "copy_via_avro",
      "batchRows": 5000,
      "maxInFlightBatches": 8,
      "staging": {
        "useTempTables": true,
        "swapAtomic": true
      }
    }
  },

  "cdc": {
    "enabled": true,
    "startPoint": {
      "strategy": "now",
      "clusterTime": null,
      "resumeToken": null
    },
    "publish": {
      "mode": "direct",
      "kafka": {
        "bootstrapServers": "kafka-1:9092",
        "sasl": null,
        "topicPrefix": "cdc.appcatalog."
      }
    },
    "retry": { "maxAttempts": 100, "backoffMs": 500 }
  },

  "collections": [
    {
      "name": "products",
      "target": {
        "baseTable": "products",
        "tablePerNested": true,
        "flattenArrays": false
      },
      "filters": { "query": { "active": true } },
      "fieldTransforms": [
        { "path": "price", "op": "toDecimal", "scale": 2 },
        { "path": "tags[]", "op": "normalizeLowercase" }
      ],
      "keys": {
        "primary": ["_id"],
        "natural": ["sku"]
      },
      "conflicts": {
        "onLoad": "upsert",
        "onCdc": "upsert"
      }
    },
    {
      "name": "orders",
      "target": {
        "baseTable": "orders",
        "tablePerNested": true
      },
      "filters": null,
      "fieldTransforms": [],
      "keys": { "primary": ["orderId"] },
      "schemaConversion": {
        "defaultStrategy": "tableize",
        "arrayStrategy": "child_table",
        "mapStrategy": "jsonb",
        "idStrategy": "uuid",
        "flattenDepth": 1,
        "pathOverrides": [
          { "path": "billingAddress", "strategy": "flatten" },
          { "path": "shippingAddress", "strategy": "flatten" },
          { "path": "meta", "strategy": "jsonb" },
          { "path": "items[]", "strategy": "tableize", "targetTable": "order_items",
            "pk": ["order_id", "line_no"], "indexes": [["sku"], ["name"]] },
          { "path": "payments[]", "strategy": "tableize", "targetTable": "order_payments",
            "pk": ["order_id", "payment_no"], "unique": [["provider", "charge_id"]] },
          { "path": "tags[]", "strategy": "junction_table", "targetTable": "order_tags",
            "pk": ["order_id", "tag"] }
        ]
      }
    }
  ],

  "safety": {
    "prechecks": ["source_reachable", "target_version", "privileges"],
    "stopIfRowCountMismatchPct": 5.0,
    "stopOnDdlError": true,
    "allowDropOnRegenerate": false
  }
}

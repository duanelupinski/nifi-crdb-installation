#cloud-config

write_files:

apt:
  sources_list: |
    deb http://deb.debian.org/debian/ $RELEASE main contrib non-free
    deb-src http://deb.debian.org/debian/ $RELEASE main contrib non-free

    deb http://deb.debian.org/debian/ $RELEASE-updates main contrib non-free
    deb-src http://deb.debian.org/debian/ $RELEASE-updates main contrib non-free

    deb http://deb.debian.org/debian-security $RELEASE-security main
    deb-src http://deb.debian.org/debian-security $RELEASE-security main
  conf: |
    APT {
      Get {
        Assume-Yes "true";
        Fix-Broken "true";
      };
    };

packages:
  - apt-transport-https
  - ca-certificates
  - curl
  - dnsutils
  - gnupg2
  - less
  - net-tools
  - screen
  - software-properties-common
  - vim

disk_setup:
  /dev/sdb:
    table_type: gpt
    layout:
      - [100, 31]
    overwrite: true
  /dev/sdc:
    table_type: gpt
    layout:
      - [100, 31]
    overwrite: true
  /dev/sdd:
    table_type: gpt
    layout:
      - [100, 31]
    overwrite: true
  /dev/sde:
    table_type: gpt
    layout:
      - [100, 31]
    overwrite: true
  /dev/sdf:
    table_type: gpt
    layout:
      - [100, 31]
    overwrite: true

runcmd:

users:
- name: debian
  gecos: Debian User
  sudo: ALL=(ALL) NOPASSWD:ALL
  shell: /bin/bash
  lock_passwd: true
  ssh-import-id: #USER-ID#
  ssh_authorized_keys:
    - #SSH-PUB-KEY#
- name: root
  lock_passwd: true

locale: en_US.UTF-8

timezone: UTC

ssh_deletekeys: 1

package_upgrade: true

ssh_pwauth: true

manage_etc_hosts: false

fqdn: #HOSTNAME#.nifi.demo

hostname: #HOSTNAME#

power_state:
  mode: reboot
  timeout: 30
  condition: true
